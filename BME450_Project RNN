ayName":"Deniz Eksioglu","userId":"05608514756759110128"},"user_tz":240},"id":"lFPaRmCB5JKh"},"outputs":[],"source":["def image_to_sequence(x):\n","    \"\"\"\n","    x: (batch, 1, 64, 64)\n","    returns: (batch, seq_len=64, input_size=64)\n","    \"\"\"\n","\n","    x = x.squeeze(1)\n","    # OR equivalently: x = x.permute(0, 2, 3, 1).squeeze(-1)\n","\n","    return x"]},{"cell_type":"code","execution_count":6,"metadata":{"executionInfo":{"elapsed":39,"status":"ok","timestamp":1776651057008,"user":{"displayName":"Deniz Eksioglu","userId":"05608514756759110128"},"user_tz":240},"id":"VbSKYQSMoCkO"},"outputs":[],"source":["class ImageRNN(nn.Module):\n","    def __init__(self, input_size=192, hidden_size=128, output_size=4):\n","        super(ImageRNN, self).__init__()\n","\n","        self.rnn = nn.RNN(input_size, hidden_size, batch_first=True)\n","        self.h2o = nn.Linear(hidden_size, output_size)\n","        self.softmax = nn.LogSoftmax(dim=1)\n","\n","    def forward(self, x):\n","\n","        # convert image → sequence\n","        x = image_to_sequence(x)\n","\n","        rnn_out, hidden = self.rnn(x)\n","\n","        output = self.h2o(hidden[-1])\n","        output = self.softmax(output)\n","\n","        return output\n","\n","def train_loop(dataloader, model, loss_fn, optimizer):\n","    size = len(dataloader.dataset)\n","\n","    model.train()\n","\n","    for batch, (X, y) in enumerate(dataloader):\n","\n","        pred = model(X)\n","        loss = loss_fn(pred, y)\n","\n","        optimizer.zero_grad()\n","        loss.backward()\n","        optimizer.step()\n","\n","        if batch % 100 == 0:\n","            print(f\"loss: {loss.item():.4f} [{batch * len(X)}/{size}]\")\n","\n","\n","def test_loop(dataloader, model, loss_fn):\n","    size = len(dataloader.dataset)\n","    num_batches = len(dataloader)\n","    test_loss, correct = 0, 0\n","\n","    with torch.no_grad():\n","        for X, y in dataloader:\n","            pred = model(X)\n","            test_loss += loss_fn(pred, y).item()\n","            correct += (pred.argmax(1) == y).type(torch.float).sum().item()\n","\n","    test_loss /= num_batches\n","    correct /= size\n","    print(f\"Test Error: \\n Accuracy: {(100*correct):\u003e0.1f}%, Avg loss: {test_loss:\u003e8f} \\n\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true,"base_uri":"https://localhost:8080/"},"id":"dhx_Wb_voqqh"},"outputs":[{"name":"stdout","output_type":"stream","text":["Epoch 1\n","-------------------------------\n","loss: -0.1571 [0/2870]\n","Test Error: \n"," Accuracy: 25.4%, Avg loss: -13.664729 \n","\n","Epoch 2\n","-------------------------------\n","loss: -13.8029 [0/2870]\n","Test Error: \n"," Accuracy: 25.4%, Avg loss: -25.069098 \n","\n","Epoch 3\n","-------------------------------\n","loss: -25.7589 [0/2870]\n","Test Error: \n"," Accuracy: 25.4%, Avg loss: -36.248147 \n","\n","Epoch 4\n","-------------------------------\n","loss: -36.7871 [0/2870]\n","Test Error: \n"," Accuracy: 25.4%, Avg loss: -47.327404 \n","\n","Epoch 5\n","-------------------------------\n","loss: -48.0504 [0/2870]\n","Test Error: \n"," Accuracy: 25.4%, Avg loss: -58.465083 \n","\n","Epoch 6\n","-------------------------------\n","loss: -59.6128 [0/2870]\n","Test Error: \n"," Accuracy: 25.4%, Avg loss: -69.529200 \n","\n","Epoch 7\n","-------------------------------\n","loss: -70.7457 [0/2870]\n","Test Error: \n"," Accuracy: 25.4%, Avg loss: -80.599365 \n","\n","Epoch 8\n","-------------------------------\n","loss: -81.4799 [0/2870]\n","Test Error: \n"," Accuracy: 25.4%, Avg loss: -91.628548 \n","\n","Epoch 9\n","-------------------------------\n","loss: -93.0698 [0/2870]\n","Test Error: \n"," Accuracy: 25.4%, Avg loss: -102.663882 \n","\n","Epoch 10\n","-------------------------------\n","loss: -104.1099 [0/2870]\n","Test Error: \n"," Accuracy: 25.4%, Avg loss: -113.706618 \n","\n","Done!\n"]}],"source":["model = ImageRNN(output_size=4)\n","\n","loss_fn = nn.NLLLoss()\n","optimizer = optim.Adam(model.parameters(), lr=1e-3)\n","\n","epochs = 10\n","\n","for t in range(epochs):\n","    print(f\"Epoch {t+1}\\n-------------------------------\")\n","    train_loop(train_dataloader, model, loss_fn, optimizer)\n","    test_loop(test_dataloader, model, loss_fn)\n","\n","print(\"Done!\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":18,"status":"ok","timestamp":1776638503957,"user":{"displayName":"Deniz Eksioglu","userId":"05608514756759110128"},"user_tz":240},"id":"WFJmdXeJw8Qa","outputId":"58f4446a-598c-4b1d-c269-1c044fa8e39b"},"outputs":[{"name":"stdout","output_type":"stream","text":["neural network output pseudo-probabilities: tensor([[-1.1979, -1.3988, -2.1137, -1.1072]])\n","neural network output class number: 3\n","neural network output, predicted class: pituitary_tumor\n"]}],"source":["sample_num = 12\n","\n","with torch.no_grad():\n","    r = model(train_data[sample_num][0].unsqueeze(0))\n","\n","print('neural network output pseudo-probabilities:', r)\n","print('neural network output class number:', torch.argmax(r).item())\n","print('neural network output, predicted class:', categories[torch.argmax(r).item()])"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":553},"executionInfo":{"elapsed":139,"status":"ok","timestamp":1776638507541,"user":{"displayName":"Deniz Eksioglu","userId":"05608514756759110128"},"user_tz":240},"id":"b8JbQUyaGRts","outputId":"a4aea1b8-7c68-4c1e-cd5f-f63af1de4c3b"},"outputs":[{"name":"stderr","output_type":"stream","text":["WARNING:matplotlib.image:Clipping input data to the valid range for imshow with RGB data ([0..1] for floats or [0..255] for integers). Got range [-0.8901961..0.85882354].\n"]},{"name":"stdout","output_type":"stream","text":["True: pituitary_tumor\n","Pred: pituitary_tumor\n","Logits: tensor([[-3.7036, -1.6673, -1.0670, -0.8152]])\